# Cloudflare Workers Static Assets — netlify-compatible header rules.
# https://developers.cloudflare.com/workers/static-assets/headers/
# This file lives in static/ and Docusaurus copies it to build/_headers.
# More-specific rules first; security defaults catch everything else.

# Docusaurus content-hashes everything under /assets/ (e.g. styles.<hash>.css,
# runtime~main.<hash>.js) — safe to cache forever. Without this rule Cloudflare
# serves them max-age=0 and they revalidate on every request.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Favicons / logos in /img are not hashed — moderate TTL keeps a swap path.
/img/*
  Cache-Control: public, max-age=2592000

# Security response headers for every route (HTML + assets).
# No Content-Security-Policy: Docusaurus relies on inline <script>/<style>
# (hydration, JSON-LD, search, embeds), so a meaningful CSP needs dedicated
# design and is tracked separately rather than shipped blind.
# HSTS is intentionally max-age only (no includeSubDomains/preload): this is a
# subdomain of hardwario.com and preload is effectively irreversible — keep it
# in step with the apex's deliberately conservative HSTS.
/*
  Strict-Transport-Security: max-age=31536000
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
